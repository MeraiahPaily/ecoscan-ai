# IPython
profile_default/
ipython_config.py

# pyenv
# For a pipeline developed-in-Pyenv, pyenv version should be set in the requirements for replayability, .python-version should be ignored.
.python-version

# pipenv
# According to pypi, pipenv >=2017.05a2 does not create .venv/, but uncommitted pip files are useful to keep around (to install deps in a recreated environment)
Pipfile.lock

# PEP 582; used by e.g. github.com/google/subpar
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

